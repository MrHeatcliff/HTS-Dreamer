.pytest_cache
dist
__pycache__/
*.py[cod]
*.egg-info
MUJOCO_LOG.TXT

# Local experiment outputs and caches.
wandb/

# Paper artifacts: commit small scripts, manifests, reports, CSV summaries, and
# figures by default. Ignore bulky generated payloads and raw event streams.
paper_artifacts/**/data/
paper_artifacts/**/run_logs/
paper_artifacts/**/*.jsonl
paper_artifacts/**/*.npz
paper_artifacts/**/*.npy
paper_artifacts/**/*.pkl
paper_artifacts/**/*.pt
paper_artifacts/**/*.pth
paper_artifacts/**/*.ckpt
logs/
runs/
tmp/
*.log

# DreamerV3 run outputs.
**/ckpt/
**/replay/
**/scope/
**/plugins/profile/

# Large media/checkpoint artifacts that should not be committed by default.
*.mp4
*.gif
*.npz
*.pkl
*.ckpt
